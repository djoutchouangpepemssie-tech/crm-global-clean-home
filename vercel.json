{
  "buildCommand": "rm -rf frontend/node_modules frontend/.next 2>/dev/null; cd frontend && npm cache clean --force && npm install --legacy-peer-deps && npm run build",
  "outputDirectory": "frontend/build",
  "env": {
    "REACT_APP_API_URL": "https://crm-global-clean-home-production.up.railway.app"
  },
  "routes": [
    {
      "src": "^/static/(.*)",
      "dest": "/static/$1",
      "headers": {
        "Cache-Control": "public, max-age=3600, immutable"
      }
    },
    {
      "src": "^/api/(.*)",
      "dest": "https://crm-global-clean-home-production.up.railway.app/api/$1",
      "methods": ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS"]
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "ignoreCommand": "git log --oneline -1 --pretty=%B | grep -q '^skip-vercel'; [ $? -eq 0 ]",
  "cleanUrls": true
}
