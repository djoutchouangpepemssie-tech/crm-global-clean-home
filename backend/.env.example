# Global Clean Home CRM - Configuration des Intégrations
# Ce fichier contient toutes les clés API et configurations

# === SMS TWILIO ===
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+33123456789

# === WHATSAPP BUSINESS (via Twilio) ===
TWILIO_WHATSAPP_NUMBER=whatsapp:+33123456789

# === STRIPE ===
STRIPE_SECRET_KEY=sk_test_your_stripe_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# === GOOGLE CALENDAR ===
GOOGLE_CALENDAR_CLIENT_ID=your_google_client_id_here
GOOGLE_CALENDAR_CLIENT_SECRET=your_google_secret_here
GOOGLE_CALENDAR_REDIRECT_URI=https://clean-home-hub-3.preview.emergentagent.com/api/calendar/callback

# === EMAIL (SMTP) ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here

# === ML MODEL ===
ML_MODEL_PATH=/app/backend/ml_model.pkl
ML_RETRAIN_SCHEDULE=daily
