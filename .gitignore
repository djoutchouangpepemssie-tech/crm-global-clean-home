# ══════════════════════════════════════════════════
# CRM Global Clean Home — .gitignore
# ══════════════════════════════════════════════════

# IDE
.idea/
.vscode/
*.swp
*.swo

# Dependencies
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# Environment files & secrets
*.env
*.env.*
!*.env.example
*token.json*
*credentials.json*

# Python
__pycache__/
*.pyc
*.pyo
venv/
.venv/
*.egg-info/
.ipynb_checkpoints/

# Build outputs
build/
dist/
.next/
out/
*.tsbuildinfo
next-env.d.ts

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dump.rdb
backend/*.log

# System files
.DS_Store
*.pem
Thumbs.db

# Testing
coverage/

# Deployment
.vercel
.cache/

# Archives & large files
*.zip
*.tar.gz
*.tar
*.tgz
*.pack
*.deb
*.dylib

# Claude Code session metadata
.claude/
